# ============================================================
#  CloudsWork — Environment Variables Reference
#  Created by: Qamar Shahzad
# ============================================================
#
#  DO NOT rename this file to .env — Replit manages secrets
#  through its own secure system, not .env files.
#
#  HOW TO SET THESE IN REPLIT:
#    Secrets (sensitive):  Use Replit Secrets panel (lock icon)
#    Non-secret vars:      Agent sets them via environment tools
# ============================================================


# ── DATABASE ────────────────────────────────────────────────
# AUTO-PROVIDED by Replit PostgreSQL. Never set manually.

# DATABASE_URL=postgresql://user:password@host:5432/dbname
# PGHOST=your-pg-host
# PGPORT=5432
# PGUSER=your-pg-user
# PGPASSWORD=your-pg-password
# PGDATABASE=your-db-name


# ── AUTH / SESSION ──────────────────────────────────────────
# Set as a Replit SECRET (not a plain env var)
# Used for session token signing/hashing
# Generate a strong random value: openssl rand -hex 64

SESSION_SECRET=your-very-long-random-secret-key-here


# ── SERVER ──────────────────────────────────────────────────
# AUTO-SET by Replit workflows. Never set manually.
# API server uses port 8080
# Frontend uses port 20174

# PORT=8080


# ── FRONTEND ────────────────────────────────────────────────
# AUTO-SET by Replit artifact routing system.

# BASE_PATH=/


# ── APP CONFIG ──────────────────────────────────────────────
# Base URL of the deployed app.
# Used to generate referral links (e.g. https://yourapp.replit.app)
# Leave empty in development (referral links use relative paths)

APP_URL=https://your-app-name.replit.app


# ── LOGGING ─────────────────────────────────────────────────
# Controls API server log verbosity.
# Values: trace | debug | info | warn | error | fatal
# Default: info

LOG_LEVEL=info


# ── NODE ENVIRONMENT ────────────────────────────────────────
# AUTO-SET by Replit workflows.
# development → pretty logs, Replit dev plugins active
# production  → JSON logs, optimized build

# NODE_ENV=development


# ============================================================
#  SUMMARY TABLE
# ============================================================
#
#  Variable         | Required | Who Sets It      | Type
#  ─────────────────────────────────────────────────────────
#  DATABASE_URL     | YES      | Replit (auto)    | auto
#  PGHOST           | YES      | Replit (auto)    | auto
#  PGPORT           | YES      | Replit (auto)    | auto
#  PGUSER           | YES      | Replit (auto)    | auto
#  PGPASSWORD       | YES      | Replit (auto)    | auto
#  PGDATABASE       | YES      | Replit (auto)    | auto
#  SESSION_SECRET   | YES      | You (Secret)     | secret ✓
#  PORT             | YES      | Replit (auto)    | auto
#  BASE_PATH        | YES      | Replit (auto)    | auto
#  APP_URL          | NO       | You (optional)   | plain
#  LOG_LEVEL        | NO       | You (optional)   | plain
#  NODE_ENV         | NO       | Replit (auto)    | auto
#
# ============================================================
